# 한국투자증권 OpenAPI
KIS_APP_KEY=your_app_key
KIS_APP_SECRET=your_app_secret
KIS_ACCOUNT_NO=12345678
KIS_ACCOUNT_PRODUCT=01

# 거래 모드: true=모의투자, false=실전투자
KIS_MOCK=true

# 무한매수법 설정
TRADING_TICKER=TQQQ
TRADING_TOTAL_CAPITAL=10000
TRADING_ROUNDS=40
TRADING_TARGET_RETURN=0.10
TRADING_EXCHANGE=NASD
TRADING_LOC_MARGIN=0.05
TRADING_MAX_DAILY_AMOUNT=5000

# 텔레그램 알림 (선택)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 스케줄러 (선택)
CRON_SCHEDULE=30 15 * * 1-5
CRON_TIMEZONE=America/New_York
